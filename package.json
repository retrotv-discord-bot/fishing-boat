{
  "name": "fishing-vessel",
  "version": "3.0.0",
  "description": "디스코드용 어선 봇",
  "license": "Apache-2.0",
  "author": "yjj8353@gmail.com",
  "type": "module",
  "main": "index.ts",
  "private": true,
  "scripts": {
    "start": "bun index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --check",
    "format:write": "prettier . --write",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:stop": "pm2 stop fishing-vessel",
    "pm2:delete": "pm2 delete fishing-vessel",
    "pm2:logs": "pm2 logs fishing-vessel",
    "pm2:logrotate:install": "pm2 install pm2-logrotate",
    "pm2:logrotate:daily": "pm2 set pm2-logrotate:rotateInterval '0 0 * * *' && pm2 set pm2-logrotate:dateFormat 'YYYY-MM-DD' && pm2 set pm2-logrotate:retain 14 && pm2 set pm2-logrotate:max_size 100M && pm2 set pm2-logrotate:compress true"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@prisma/adapter-libsql": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "croner": "^10.0.1",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "ky": "^1.14.3",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "eslint-plugin-n": "^17.24.0",
    "globals": "^17.4.0",
    "pino-pretty": "^13.1.3",
    "pm2": "^6.0.14",
    "prettier": "^3.8.1",
    "prisma": "^7.5.0",
    "typescript-eslint": "^8.57.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
